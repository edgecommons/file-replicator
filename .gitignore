# Rust
/target
**/*.rs.bk

# Local-dev override: point edgecommons at the sibling libs/rust instead of the pinned git rev.
# Gitignored so CI uses the git rev; see the org CLAUDE.md "Local-dev notes".
/.cargo/config.toml

# Greengrass build output
/greengrass-build
/zip-build

# Local runtime data (durable state, vault, spool/archive scratch)
/data
*.redb
vault.json
# Durable SQLite state written to the process CWD when run locally (+ WAL/SHM sidecars)
file-replicator-state.db*
# Local run logs (e.g. the metricEmission log sink's default output)
/logs/

# OS / editor
.DS_Store
Thumbs.db
